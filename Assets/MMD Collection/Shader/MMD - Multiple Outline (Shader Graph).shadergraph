{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "e1e85271f75a41c9b959cf0e021659cc",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ProceduralMultiShellOutline (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -655.1998901367188,
            "y": 199.99998474121095,
            "width": 246.39999389648438,
            "height": 373.59991455078127
        }
    },
    "m_Slots": [
        {
            "m_Id": "a954261ddc44424e875839f489e34dee"
        },
        {
            "m_Id": "7cc7543664e34fa29eb253617cf8b0cb"
        },
        {
            "m_Id": "09d49340e06143b1aa0e8a87d08b70d6"
        },
        {
            "m_Id": "39ce0fff62c54a048a6d130882db7f15"
        },
        {
            "m_Id": "4925ff429097457ea8c2835b15e14a1c"
        },
        {
            "m_Id": "c8ba1ba5781749f69d8c3e4e35874b5a"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": true,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "ProceduralMultiShellOutline",
    "m_FunctionSource": "b137e659a6c74d9429e1c0b8b55c4125",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "// Normalize the surface normal.\r\nfloat3 N = normalize(normalWS);\r\n\r\n// Normalize the camera view direction.\r\nfloat3 V = normalize(viewDirectionWS);\r\n\r\n// Compute the facing ratio between the camera and surface.\r\n// \r\n// Result:\r\n// - 1.0 = surface directly facing the camera.\r\n// - 0.0 = surface perpendicular to the camera.\r\n// \r\n// This matches the original shader rim intensity behavior.\r\nfloat r = saturate(dot(V, N));\r\n\r\n// Select layer count.\r\n// \r\n// outlineLayers:\r\n// - 0 = 4 shell layers.\r\n// - 1 = 8 shell layers.\r\nint layers = (outlineLayers < 0.5) ? 4 : 8;\r\n\r\n// Stores the accumulated alpha result.\r\nfloat alphaSum = 0.0;\r\n\r\n// Simulate all shell passes procedurally.\r\n[loop]\r\nfor (int i = 1; i <= layers; i++)\r\n{\r\n    // Compute the alpha scale for this layer.\r\n    // \r\n    // Outer layers are weaker.\r\n    // Inner layers become progressively stronger.\r\n    // \r\n    // Examples for 4 layers:\r\n    // - 0.25\r\n    // - 0.50\r\n    // - 0.75\r\n    // - 1.00\r\n    float layerAlphaScale = (float)i / (float)layers;\r\n\r\n    // Default processed rim value.\r\n    float r_processed = r;\r\n\r\n    // Optional stepped shell simulation.\r\n    // \r\n    // This reproduces the original layered shell appearance where\r\n    // each shell activates at a different threshold instead of using\r\n    // a fully smooth gradient.\r\n    if (useStepped > 0.5)\r\n    {\r\n        // Compute activation threshold for this shell layer.\r\n        float threshold = (float)(i - 1) / (float)layers;\r\n\r\n        // Convert the smooth rim into a shell step.\r\n        // \r\n        // Result:\r\n        // - 0.0 = shell inactive.\r\n        // - 1.0 = shell active.\r\n        r_processed = step(threshold, r);\r\n    }\r\n\r\n    // Compute current layer alpha contribution.\r\n    float layerAlpha = r_processed * layerAlphaScale;\r\n\r\n    // Accumulate alpha using layered transparency blending.\r\n    // \r\n    // This simulates:\r\n    // Blend SrcAlpha OneMinusSrcAlpha\r\n    // \r\n    // Used by the original multi-pass MMD shader.\r\n    alphaSum = layerAlpha + alphaSum * (1.0 - layerAlpha);\r\n}\r\n\r\n// Output final outline color.\r\n// \r\n// Alpha is clamped to prevent overflow.\r\nColor = float4(outlineColor.rgb, saturate(alphaSum) * outlineColor.a);"
}

