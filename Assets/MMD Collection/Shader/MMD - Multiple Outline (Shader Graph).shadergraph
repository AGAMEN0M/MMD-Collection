{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "5abe4a1da4e44c09b91eb97000eebc36",
    "m_Title": "MMD Procedural Multi Shell Outline",
    "m_Content": "Simulates the original MMD multi-pass outline shader behavior inside a\r\nsingle Shader Graph Custom Function.\r\n\r\nThis function reproduces:\r\n- Layered shell alpha accumulation.\r\n- Progressive outline opacity buildup.\r\n- Optional stepped shell transitions.\r\n- 4 layer and 8 layer outline modes.\r\n\r\nIntended for:\r\n- Unity 6 URP.\r\n- Shader Graph Custom Function nodes.\r\n- Single pass procedural outline rendering.\r\n\r\nNotes:\r\n- Vertex extrusion must be handled externally in Shader Graph.\r\n- This function only computes the final outline color and alpha.\r\n- Alpha accumulation uses layered transparency blending similar to the\r\n  original multi-pass shader.",
    "m_TextSize": 0,
    "m_Theme": 0,
    "m_Position": {
        "serializedVersion": "2",
        "x": -647.2000122070313,
        "y": 608.0,
        "width": 391.20001220703127,
        "height": 325.5999755859375
    },
    "m_Group": {
        "m_Id": ""
    }
}

{
    "m_SGVersion": 0,
    "m_Type": "UnityEditor.ShaderGraph.StickyNoteData",
    "m_ObjectId": "68e022f8f98e4bec9a4cd8ba25aee98e",
    "m_Title": "⚠️ WARNING ⚠️",
    "m_Content": "This shader is a procedural approximation of the original multi-pass MMD outline shader.\n\nUnlike the original version that supported hard edges,\nthis implementation requires smooth normals to produce proper results.\n\nAccurate reproduction of the original effect would require true multi-pass support in URP.",
